{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["bin/**/*", "lib/**/*"]
}